# Set default behavior to automatically normalize line endings.
* text=auto

# Force bash scripts to use LF line endings
*.sh text eol=lf

# Force batch files to use CRLF line endings
*.bat text eol=crlf

# Force specific files to use LF line endings
*.json text eol=lf
*.js text eol=lf
*.ts text eol=lf
*.tsx text eol=lf
*.css text eol=lf
*.md text eol=lf

# Force specific files to use CRLF line endings
*.ps1 text eol=crlf
*.cmd text eol=crlf
